---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Privacy Policy | Project KAI"
  description="Privacy policy for the static Project KAI website and KAI OS launch pages."
  canonicalPath="/privacy"
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">Privacy</p>
        <h1 class="page-title">Privacy Policy</h1>
        <p class="page-lede">
          Project KAI is a simple static website for KAI OS. It does not include accounts, payments, backend forms, analytics integrations, or credential collection.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>Data Collection</h2>
          <p>Project KAI does not intentionally collect personal data through this static website.</p>
        </article>

        <article class="content-card">
          <h2>Analytics</h2>
          <p>No analytics service is connected in this version of the site.</p>
        </article>

        <article class="content-card">
          <h2>Contact</h2>
          <p>If a contact method is provided later, any submitted information should be handled through that chosen channel.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
