---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="KAI OS Agents | AI Agent Ecosystem"
  description="Explore the KAI OS agent ecosystem for research, content creation, automation, business planning, development, and long-term workflow improvement."
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">AI Agent Ecosystem</p>
        <h1 class="page-title">Specialized agents for research, content, automation, business, and system growth.</h1>
        <p class="page-lede">
          KAI OS uses focused agents as building blocks. Each agent can be improved independently and connected to broader workflows only when the system is ready.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>Developer Agent</h2>
          <p>Supports code, documentation, architecture reviews, and practical software improvement.</p>
        </article>

        <article class="content-card">
          <h2>Content Agent</h2>
          <p>Supports articles, scripts, publication planning, editorial workflows, and launch-ready content systems.</p>
        </article>

        <article class="content-card">
          <h2>Research Agent</h2>
          <p>Explores AI, automation, software systems, business models, and emerging technology patterns.</p>
        </article>

        <article class="content-card">
          <h2>Business Agent</h2>
          <p>Plans offers, monetization paths, digital products, and practical income systems.</p>
        </article>

        <article class="content-card">
          <h2>Automation Agent</h2>
          <p>Designs controlled workflows for repeated tasks, operations, reporting, and launch execution.</p>
        </article>

        <article class="content-card">
          <h2>Meta Agent</h2>
          <p>Coordinates progress, captures lessons, tracks decisions, and supports long-term system alignment.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
