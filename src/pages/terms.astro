---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Terms | KAI OS"
  description="Terms for using the static KAI OS website and launch materials."
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">Terms</p>
        <h1 class="page-title">Terms of Use</h1>
        <p class="page-lede">
          KAI OS content is provided for informational and educational purposes. The website does not provide financial, legal, medical, or investment advice.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>Use of Content</h2>
          <p>Website content may describe AI workflows, automation concepts, and digital systems. Review and adapt any ideas responsibly.</p>
        </article>

        <article class="content-card">
          <h2>No Guarantees</h2>
          <p>KAI OS does not guarantee income, traffic, rankings, automation outcomes, business results, or technical results.</p>
        </article>

        <article class="content-card">
          <h2>Manual Review</h2>
          <p>AI-assisted workflows should be reviewed by a human before publication, business use, or operational decisions.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
