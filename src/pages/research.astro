---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Project KAI Research | KAI OS AI Systems Lab"
  description="Project KAI research explores KAI OS agents, automation, content systems, digital business, memory, safety, and intelligent workflows."
  canonicalPath="/research"
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">Research Lab</p>
        <h1 class="page-title">Research that turns AI ideas into usable systems.</h1>
        <p class="page-lede">
          Project KAI research is focused on the practical questions behind KAI OS workflows: what to automate, what to keep manual, how to review output, and how to improve safely over time.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card">
          <h2>AI Agents</h2>
          <p>Reasoning, planning, memory, agent boundaries, and controlled execution patterns.</p>
        </article>

        <article class="content-card">
          <h2>Automation</h2>
          <p>Repeatable workflows, manual approval gates, launch operations, and practical system design.</p>
        </article>

        <article class="content-card">
          <h2>Digital Business</h2>
          <p>Content pipelines, newsletters, publication planning, product ideas, and monetization readiness.</p>
        </article>

        <article class="content-card">
          <h2>Memory Systems</h2>
          <p>Reports, validation records, roadmaps, decision logs, and structured knowledge reuse.</p>
        </article>

        <article class="content-card">
          <h2>Safety</h2>
          <p>Human oversight, rollback plans, protected directories, frozen baselines, and no-automation boundaries.</p>
        </article>

        <article class="content-card">
          <h2>Long-Term Evolution</h2>
          <p>Continuous improvement through review, documentation, controlled implementation, and phase-based planning.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
