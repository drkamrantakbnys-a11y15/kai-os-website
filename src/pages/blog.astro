---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="KAI OS Blog | AI Workflows and Launch Notes"
  description="Read practical KAI OS articles about AI workflows, automation, research, content systems, and digital business."
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">KAI OS Blog</p>
        <h1 class="page-title">Practical notes on AI workflows, agents, and digital systems.</h1>
        <p class="page-lede">
          The blog will publish practical articles from the KAI OS build process, starting with a manual-first guide for solo creators.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card article-card">
          <span class="status-pill">Ready for publication</span>
          <h2>A Practical Guide to Practical AI Workflows for Solo Creators</h2>
          <p>
            A practical, human-reviewed guide for solo creators who want to choose one useful AI workflow, test it manually, and keep the process controlled.
          </p>
          <p>
            Publication package prepared. Live publication is pending final manual approval.
          </p>
        </article>

        <article class="content-card article-card">
          <span class="status-pill">Coming Soon</span>
          <h2>How AI Agents Can Support Solo Builders</h2>
          <p>
            A practical look at how focused AI agents can support planning, research, content, and execution without replacing human judgment.
          </p>
        </article>

        <article class="content-card article-card">
          <span class="status-pill">Coming Soon</span>
          <h2>Building a Practical AI Workflow System</h2>
          <p>
            Notes on designing small, repeatable AI workflows that remain reviewable, useful, and safe to improve over time.
          </p>
        </article>

        <article class="content-card article-card">
          <span class="status-pill">Coming Soon</span>
          <h2>The KAI OS Roadmap: From Website to AI Ecosystem</h2>
          <p>
            A roadmap view of how KAI OS can evolve from a public launch site into a larger modular AI operating system.
          </p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
