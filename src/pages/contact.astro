---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact Project KAI | KAI OS Collaboration"
  description="Contact Project KAI for collaboration, research, launch, and practical KAI OS workflow inquiries."
  canonicalPath="/contact"
>
  <Header />

  <main class="page-main">
    <section class="page-hero">
      <div class="container">
        <p class="page-kicker">Contact</p>
        <h1 class="page-title">Start a conversation about AI systems, workflows, and launch strategy.</h1>
        <p class="page-lede">
          Project KAI is currently focused on KAI OS launch readiness, manual publication, and practical AI workflow research.
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container content-grid">
        <article class="content-card wide-card">
          <h2>Contact Path</h2>
          <p>
            Use your preferred direct contact channel for now. A backend form, CRM, newsletter signup, and analytics stack are intentionally not connected yet.
          </p>
        </article>

        <article class="content-card">
          <h2>Current Availability</h2>
          <p>
            Open to conversations about AI automation, research systems, content workflows, and digital business infrastructure.
          </p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
