---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = "Project KAI | KAI OS Modular AI Operating System",
  description = "Project KAI is the public home of KAI OS, a modular AI operating system for automation, research, content creation, digital business, and intelligent workflows.",
  canonicalPath = "/"
} = Astro.props;

const canonicalUrl = canonicalPath === "/"
  ? "https://projectkai.dev/"
  : `https://projectkai.dev${canonicalPath}`;
---

<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="theme-color"
    content="#050b18"
  />

  <meta
    name="robots"
    content="index, follow"
  />

  <link
    rel="canonical"
    href={canonicalUrl}
  />

  <meta
    property="og:title"
    content={title}
  />

  <meta
    property="og:description"
    content={description}
  />

  <meta
    property="og:url"
    content={canonicalUrl}
  />

  <meta
    property="og:type"
    content="website"
  />

  <link
    rel="icon"
    type="image/svg+xml"
    href="/favicon.svg"
  />

  <link
    rel="icon"
    href="/favicon.ico"
  />

</head>

<body>

  <slot />

</body>

</html>
