---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "KAI OS | The Self-Evolving AI Operating System",
  description = "KAI OS is a modular AI operating system designed to automate work, build intelligent agents, create digital businesses, and evolve through continuous learning."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="theme-color"
    content="#050b18"
  />

  <meta
    name="robots"
    content="index, follow"
  />

  <link
    rel="icon"
    type="image/svg+xml"
    href="/favicon.svg"
  />

  <link
    rel="icon"
    href="/favicon.ico"
  />

</head>

<body>

  <slot />

</body>

</html>